# MongoDB connection string for the LMS database.
MONGODB_URI=mongodb://127.0.0.1:27017/lms

# HTTP port the API listens on.
PORT=3001

# JWT auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Default admin created by `pnpm seed` (seedAdmin). Uncomment to override the defaults below.
# ADMIN_EMAIL=admin@vuonvan.vn
# ADMIN_PASSWORD=admin123456
