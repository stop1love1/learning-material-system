# MongoDB connection string for the LMS database.
MONGODB_URI=mongodb://127.0.0.1:27017/lms

# HTTP port the API listens on.
PORT=3001

# JWT auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Default admin created by `pnpm seed` (seedAdmin). Uncomment to override the defaults below.
# ADMIN_EMAIL=admin@vuonvan.vn
# ADMIN_PASSWORD=admin123456

# URL của frontend — dùng để dựng link xác thực email / đặt lại mật khẩu trong email.
FRONTEND_URL=http://localhost:3000

# Google Sign-In: OAuth 2.0 Web client ID (Google Cloud Console). Phải TRÙNG với
# NEXT_PUBLIC_GOOGLE_CLIENT_ID ở frontend; backend dùng để verify ID token (audience).
# Bỏ trống = tắt đăng nhập bằng Google.
GOOGLE_CLIENT_ID=

# SMTP gửi email. Bỏ trống SMTP_HOST = chế độ DEV (không gửi thật, log link + trả devLink).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vườn Văn <no-reply@vuonvan.vn>
