
# --- Backend ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Admin mặc định (tự tạo khi backend khởi động)
ADMIN_EMAIL=admin@vuonvan.vn
ADMIN_PASSWORD=admin123456

# Google Sign-In (phải trùng NEXT_PUBLIC_GOOGLE_CLIENT_ID). Bỏ trống = tắt.
GOOGLE_CLIENT_ID=

# SMTP gửi email. Bỏ trống SMTP_HOST = chế độ DEV (không gửi thật).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vườn Văn <no-reply@vuonvan.vn>

# --- Frontend (nhúng lúc build, đổi giá trị phải build lại) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
