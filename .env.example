# ============================================================
#  Biến môi trường cho image GỘP (backend + frontend, 1 Dockerfile ở gốc).
#  Trên Coolify: đặt trong "Environment Variables" của resource.
#    - NEXT_PUBLIC_* : dùng LÚC BUILD (Coolify tự truyền làm --build-arg, nhúng
#      vào bundle frontend → đổi phải build lại).
#    - Còn lại       : dùng LÚC CHẠY (runtime).
#  Container lắng nghe FRONTEND ở PORT (mặc định 3000 của Next). Muốn map ra
#  cổng host khác thì cấu hình "Ports Mappings" trong Coolify. Backend 3001 chỉ
#  NỘI BỘ, không ra ngoài — trình duyệt gọi /api và Next proxy sang backend.
# ============================================================

# --- Backend (runtime) ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/lms?retryWrites=true&w=majority
JWT_SECRET=<chuoi-ngau-nhien-manh->=32-ky-tu>
JWT_EXPIRES_IN=7d
# URL PUBLIC của app (dùng cho CORS + link xác thực email trỏ về).
FRONTEND_URL=https://your-domain

# Admin mặc định (tạo idempotent khi khởi động).
ADMIN_EMAIL=admin@vuonvan.vn
ADMIN_PASSWORD=<doi-mat-khau-manh>

# Google Sign-In phía server (verify id_token). PHẢI TRÙNG NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# SMTP gửi email. Bỏ trống SMTP_HOST = chế độ DEV (không gửi thật).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vườn Văn <no-reply@vuonvan.vn>

# (tuỳ chọn) cổng frontend public trong container.
# PORT=3000
# (tuỳ chọn) URL backend nội bộ cho SSR + proxy. Mặc định http://127.0.0.1:3001
# INTERNAL_API_URL=http://127.0.0.1:3001

# --- Frontend (BUILD ARGS — nhúng lúc build) ---
# Trình duyệt gọi same-origin /api → Next proxy sang backend nội bộ. Để nguyên /api.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
