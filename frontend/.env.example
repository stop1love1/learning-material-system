# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Google Drive Picker (cho phép admin kéo file từ Google Drive vào Kho tài liệu).
# Tạo tại Google Cloud Console: bật "Google Picker API" + "Google Drive API",
# tạo OAuth 2.0 Client ID (Web) với Authorized JavaScript origins = http://localhost:3000,
# và một API key. Bỏ trống = nút Google Drive sẽ báo "chưa cấu hình".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
