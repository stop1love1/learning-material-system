# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Google OAuth 2.0 Web Client ID — dùng cho CẢ:
#   1) Đăng nhập bằng Google (Google Sign-In). Backend phải đặt GOOGLE_CLIENT_ID = giá trị này.
#   2) Google Drive Picker (kéo file từ Drive vào Kho tài liệu) — cần thêm NEXT_PUBLIC_GOOGLE_API_KEY.
# Tạo tại Google Cloud Console: OAuth consent + OAuth 2.0 Client ID (Web) với
# Authorized JavaScript origins = http://localhost:3000. Bỏ trống = ẩn nút Google.
#
# LƯU Ý: NEXT_PUBLIC_* được nhúng LÚC BUILD (không đọc runtime) và .env.local bị .dockerignore
# loại khỏi image → build Docker sẽ KHÔNG có các khoá này trừ khi truyền --build-arg. Cho Drive
# Picker, cách khuyến nghị là nhập Client ID + API Key ở khu quản trị (Cài đặt → Tích hợp): lưu
# trong Mongo (settings.integration.google*), đọc runtime, đổi khoá không cần build lại. Hai biến
# dưới đây chỉ là FALLBACK khi Settings để trống.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
